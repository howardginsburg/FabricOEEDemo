<Window x:Class="FabricOEESimulator.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FabricOEESimulator.Wpf.ViewModels"
        xmlns:controls="clr-namespace:FabricOEESimulator.Wpf.Controls"
        Title="OEE Factory Floor Simulator"
        Width="1600" Height="900"
        MinWidth="1200" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Top bar -->
            <RowDefinition Height="*"/>      <!-- Main content -->
            <RowDefinition Height="160"/>    <!-- Bottom telemetry log -->
        </Grid.RowDefinitions>

        <!-- ===== TOP BAR ===== -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <TextBlock Text="OEE Factory Floor Simulator" Style="{StaticResource HeaderText}"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Border Style="{StaticResource PanelBorder}" Margin="8,0" Padding="10,4"
                            Background="{StaticResource PanelBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Parts: " Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalPartsProduced, StringFormat=N0}"
                                       Style="{StaticResource MetricValue}" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorder}" Margin="8,0" Padding="10,4"
                            Background="{StaticResource PanelBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Stations: " Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalStations}"
                                       Style="{StaticResource MetricValue}" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorder}" Margin="8,0" Padding="10,4"
                            Background="{StaticResource PanelBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Faults: " Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalFaults}" Foreground="#FFE74C3C"
                                       Style="{StaticResource MetricValue}" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>  <!-- Line selector -->
                <ColumnDefinition Width="*"/>    <!-- Factory floor -->
                <ColumnDefinition Width="280"/>  <!-- Details panel -->
            </Grid.ColumnDefinitions>

            <!-- LEFT: Line Selector -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock Text="Production Lines" Style="{StaticResource SubHeaderText}"
                               Margin="12,10" DockPanel.Dock="Top"/>

                    <ListBox ItemsSource="{Binding Lines}"
                             SelectedItem="{Binding SelectedLine}"
                             Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource LineListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ProductionLineViewModel}">
                                <StackPanel Margin="4,2">
                                    <TextBlock Text="{Binding LineName}" Style="{StaticResource BodyText}" FontWeight="Medium"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding StationCount, StringFormat={}{0} stations}"
                                                   Style="{StaticResource CaptionText}"/>
                                        <TextBlock Text=" | " Style="{StaticResource CaptionText}"/>
                                        <TextBlock Text="{Binding PartsProduced, StringFormat={}{0:N0} parts}"
                                                   Style="{StaticResource CaptionText}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FaultCount}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="!" Foreground="#FFE74C3C" FontWeight="Bold" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding FaultCount, StringFormat={}{0} fault(s)}"
                                                   Foreground="#FFE74C3C" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- CENTER: Factory Floor -->
            <controls:FactoryFloorControl Grid.Column="1"
                                          DataContext="{Binding SelectedLine}"
                                          SelectedStation="{Binding DataContext.SelectedStation, RelativeSource={RelativeSource AncestorType=Window}}"/>

            <!-- RIGHT: Details Panel -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,10">
                        <!-- Selected Station Details -->
                        <TextBlock Text="Station Details" Style="{StaticResource SubHeaderText}" Margin="0,0,0,8"/>
                        <controls:StationDetailsPanel DataContext="{Binding SelectedStation}"
                                                       Visibility="{Binding DataContext.SelectedStation, 
                                                       RelativeSource={RelativeSource AncestorType=Window},
                                                       Converter={StaticResource BoolToVisibility}}"/>

                        <TextBlock Text="No station selected" Style="{StaticResource CaptionText}"
                                   Margin="0,20"
                                   Visibility="{Binding DataContext.SelectedStation,
                                   RelativeSource={RelativeSource AncestorType=Window},
                                   Converter={StaticResource BoolToVisibility},
                                   ConverterParameter=Invert}"/>

                        <!-- Maintenance Board -->
                        <TextBlock Text="Maintenance" Style="{StaticResource SubHeaderText}" Margin="0,16,0,8"/>
                        <controls:MaintenanceBoardControl DataContext="{Binding DataContext.Maintenance,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ===== BOTTOM: Telemetry Log ===== -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <controls:TelemetryLogControl DataContext="{Binding TelemetryLog}"/>
        </Border>
    </Grid>
</Window>
