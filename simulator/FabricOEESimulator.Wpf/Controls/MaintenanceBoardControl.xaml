<UserControl x:Class="FabricOEESimulator.Wpf.Controls.MaintenanceBoardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,0,6">
            <Run Text="Active: "/>
            <Run Text="{Binding ActiveCount, Mode=OneWay}"/>
        </TextBlock>

        <ItemsControl ItemsSource="{Binding ActiveOrders}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource PanelBorder}" Margin="0,3" Padding="8,6"
                            Background="{StaticResource PanelBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding DeviceId}" Style="{StaticResource BodyText}"
                                           FontWeight="Medium" FontSize="11"/>
                                <TextBlock Style="{StaticResource CaptionText}" FontSize="9">
                                    <Run Text="WO: "/>
                                    <Run Text="{Binding Id, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Border Grid.Column="1" CornerRadius="3" Padding="6,2"
                                    Background="{StaticResource AccentBrush}" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="No active work orders"
                   Margin="0,8" FontStyle="Italic">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActiveCount}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </StackPanel>
</UserControl>
