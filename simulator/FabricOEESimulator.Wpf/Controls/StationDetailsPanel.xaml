<UserControl x:Class="FabricOEESimulator.Wpf.Controls.StationDetailsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <!-- Machine icon large -->
        <Image Width="64" Height="64" Margin="0,0,0,8" HorizontalAlignment="Center"
               Source="{Binding MachineType, Converter={StaticResource MachineTypeToIcon}}"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <TextBlock Text="{Binding MachineType}" Style="{StaticResource SubHeaderText}"
                   TextAlignment="Center" Margin="0,0,0,2"/>
        <TextBlock Text="{Binding DeviceId}" Style="{StaticResource CaptionText}"
                   TextAlignment="Center" Margin="0,0,0,8"/>

        <!-- Status badge -->
        <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Center" Margin="0,0,0,12"
                Background="{Binding Status, Converter={StaticResource StatusToColor}}">
            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                       Foreground="White" FontWeight="Bold" FontSize="12"/>
        </Border>

        <!-- Metrics grid -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cycle Time:" Style="{StaticResource CaptionText}" Margin="0,3"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource BodyText}" Margin="8,3"
                       Text="{Binding LastCycleTime, StringFormat={}{0:F1}s}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Parts:" Style="{StaticResource CaptionText}" Margin="0,3"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource BodyText}" Margin="8,3"
                       Text="{Binding TotalPartsProcessed, StringFormat=N0}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Rejected:" Style="{StaticResource CaptionText}" Margin="0,3"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource BodyText}" Margin="8,3"
                       Foreground="#FFE74C3C"
                       Text="{Binding RejectedParts, StringFormat=N0}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Reject Rate:" Style="{StaticResource CaptionText}" Margin="0,3"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource BodyText}" Margin="8,3"
                       Text="{Binding RejectRate, StringFormat={}{0:F1}%}"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Input Buffer:" Style="{StaticResource CaptionText}" Margin="0,3"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource BodyText}" Margin="8,3">
                <Run Text="{Binding InputBufferCount, Mode=OneWay}"/>
                <Run Text="/"/>
                <Run Text="{Binding BufferCapacity, Mode=OneWay}"/>
            </TextBlock>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Output Buffer:" Style="{StaticResource CaptionText}" Margin="0,3"/>
            <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource BodyText}" Margin="8,3">
                <Run Text="{Binding OutputBufferCount, Mode=OneWay}"/>
                <Run Text="/"/>
                <Run Text="{Binding BufferCapacity, Mode=OneWay}"/>
            </TextBlock>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Current Part:" Style="{StaticResource CaptionText}" Margin="0,3"/>
            <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource BodyText}" Margin="8,3"
                       Text="{Binding CurrentPartId, TargetNullValue='—'}"/>
        </Grid>
    </StackPanel>
</UserControl>
