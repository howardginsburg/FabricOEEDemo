<UserControl x:Class="FabricOEESimulator.Wpf.Controls.TelemetryLogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="12,8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Telemetry Log" Style="{StaticResource SubHeaderText}"/>
            <TextBlock Style="{StaticResource CaptionText}" VerticalAlignment="Center" Margin="12,0,0,0">
                <Run Text="{Binding Entries.Count, Mode=OneWay}"/>
                <Run Text=" events"/>
            </TextBlock>
        </StackPanel>

        <ListView ItemsSource="{Binding Entries}"
                  Background="Transparent" BorderThickness="0"
                  Foreground="{StaticResource PrimaryTextBrush}"
                  FontFamily="Consolas" FontSize="11"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.View>
                <GridView>
                    <GridView.ColumnHeaderContainerStyle>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="Padding" Value="6,3"/>
                            <Setter Property="FontSize" Value="10"/>
                        </Style>
                    </GridView.ColumnHeaderContainerStyle>
                    <GridViewColumn Header="Time" Width="80"
                                    DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss}"/>
                    <GridViewColumn Header="Type" Width="70"
                                    DisplayMemberBinding="{Binding EventType}"/>
                    <GridViewColumn Header="Device" Width="120"
                                    DisplayMemberBinding="{Binding DeviceId}"/>
                    <GridViewColumn Header="Details" Width="400"
                                    DisplayMemberBinding="{Binding JsonPayload}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>
