<UserControl x:Class="FabricOEESimulator.Wpf.Controls.AllLinesOverview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FabricOEESimulator.Wpf.ViewModels"
             xmlns:controls="clr-namespace:FabricOEESimulator.Wpf.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Lines}" Margin="16">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ProductionLineViewModel}">
                    <Border Margin="0,0,0,12" Padding="12" CornerRadius="6"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Cursor="Hand"
                            MouseLeftButtonDown="LineCard_Click" Tag="{Binding}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Line header -->
                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <TextBlock Text="{Binding LineName}" Style="{StaticResource SubHeaderText}" DockPanel.Dock="Left"/>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                    <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,12,0">
                                        <Run Text="{Binding PartsProduced, StringFormat=N0, Mode=OneWay}"/>
                                        <Run Text=" parts"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#FFE74C3C" FontSize="10" FontWeight="Bold"
                                               Visibility="{Binding FaultCount, Converter={StaticResource BoolToVisibility}}">
                                        <Run Text="{Binding FaultCount, Mode=OneWay}"/>
                                        <Run Text=" fault(s)"/>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>

                            <!-- Station dots row -->
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Stations}" Margin="0,0,0,6">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:StationViewModel}">
                                        <Border Width="28" Height="28" CornerRadius="4" Margin="2"
                                                Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                ToolTip="{Binding MachineType}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPulsing}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="OverviewPulse">
                                                                    <Storyboard RepeatBehavior="Forever">
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="1" To="0.3" Duration="0:0:0.6"
                                                                                         AutoReverse="True"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="OverviewPulse"/>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Position}" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Sparkline -->
                            <controls:SparklineControl Grid.Row="2" Height="30"
                                                        Values="{Binding ThroughputHistory}"
                                                        LineBrush="#FF2ECC71"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
